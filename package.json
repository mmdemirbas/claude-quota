{
  "name": "@mmdemirbas/claude-quota",
  "version": "0.2.4",
  "description": "Compact quota-focused statusline for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-quota": "dist/index.js"
  },
  "files": [
    "dist/",
    "src/",
    ".claude-plugin/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "lint": "tsc --noEmit && eslint src/ test/",
    "test:stdin": "echo '{\"model\":{\"display_name\":\"Claude Sonnet 4.6\"},\"effort_level\":\"high\",\"context_window\":{\"current_usage\":{\"input_tokens\":45000},\"context_window_size\":200000},\"cwd\":\"/Users/md/code/lakelab\"}' | node dist/index.js"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "quota"
  ],
  "author": "Muhammed Demirbas <https://github.com/mdemirbas>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmdemirbas/claude-quota.git"
  },
  "homepage": "https://github.com/mmdemirbas/claude-quota#readme",
  "bugs": {
    "url": "https://github.com/mmdemirbas/claude-quota/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0"
  }
}
